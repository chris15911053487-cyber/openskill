# Host port to expose. Container always listens on 3000 internally.
HOST_PORT=8088

# Required: secret used to sign JWT tokens (32+ random chars)
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin password (only used on first DB init)
ADMIN_INITIAL_PASSWORD=admin123

# Initial admin username/email (only used on first DB init)
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_EMAIL=admin@example.com

# Max upload size in MB
MAX_UPLOAD_MB=20
