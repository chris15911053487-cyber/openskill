# Server config — used both in dev and inside docker container
PORT=3000
HOST=0.0.0.0

# Path of SQLite database file
DB_PATH=../data/openskill.db

# Directory for uploaded skill ZIPs
STORAGE_DIR=../data/storage

# JWT settings
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Initial admin (only seeded on first DB init)
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=admin123

# Upload size limit (MB)
MAX_UPLOAD_MB=20

# LLM API (OpenAI-compatible endpoint)
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
